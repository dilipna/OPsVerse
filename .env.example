# Copy to .env and adjust. Never commit .env.
OPSVERSE_ENVIRONMENT=dev

# Postgres
OPSVERSE_DATABASE_URL=postgresql+asyncpg://opsverse:opsverse@localhost:5432/opsverse

# Redis
OPSVERSE_REDIS_URL=redis://localhost:6379/0

# Qdrant
OPSVERSE_QDRANT_URL=http://localhost:6333

# MinIO (S3-compatible object storage)
OPSVERSE_MINIO_ENDPOINT=http://localhost:9000
OPSVERSE_MINIO_ACCESS_KEY=opsverse
OPSVERSE_MINIO_SECRET_KEY=opsverse-secret
OPSVERSE_MINIO_BUCKET_RAW=opsverse-raw

# LLM providers (free tiers) — filled in from Phase 3 onward
# GEMINI_API_KEY=
# GROQ_API_KEY=
