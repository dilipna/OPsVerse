# Copy to .env and adjust. Never commit .env.
OPSVERSE_ENVIRONMENT=dev

# Postgres
OPSVERSE_DATABASE_URL=postgresql+asyncpg://opsverse:opsverse@localhost:5432/opsverse

# Redis
OPSVERSE_REDIS_URL=redis://localhost:6379/0

# Qdrant
OPSVERSE_QDRANT_URL=http://localhost:6333

# MinIO (S3-compatible object storage)
OPSVERSE_MINIO_ENDPOINT=http://localhost:9000
OPSVERSE_MINIO_ACCESS_KEY=opsverse
OPSVERSE_MINIO_SECRET_KEY=opsverse-secret
OPSVERSE_MINIO_BUCKET_RAW=opsverse-raw

# LLM providers (free tiers) — filled in from Phase 3 onward
# GEMINI_API_KEY=
# GROQ_API_KEY=

# Observability (Phase 8): set the host to enable Langfuse tracing. Empty =
# tracing off (NullTracer). The compose `full` profile serves Langfuse on
# :3002 and bootstraps these exact keys.
# OPSVERSE_LANGFUSE_HOST=http://localhost:3002
# OPSVERSE_LANGFUSE_PUBLIC_KEY=pk-lf-opsverse-public
# OPSVERSE_LANGFUSE_SECRET_KEY=sk-lf-opsverse-secret

# LLM gateway (Phase 6): daily USD kill-switch; 0 disables it.
# OPSVERSE_GATEWAY_DAILY_BUDGET_USD=1.0
